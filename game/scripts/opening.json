{
  "script_id": "opening_forest_only_01",
  "title": "숲에 간 곰과 수상한 토끼",
  "stage": "stage1",
  "characters": {
    "add": {
      "name": "애드",
      "expressions": {
        "add_neutral_tired": "지쳤지만 기본 상태",
        "add_confused": "당황함 / 어리둥절",
        "add_tsukkomi": "버럭 태클함 / 어이없음",
        "add_gloomy": "시무룩함 / 풀이 죽음",
        "add_proud": "뿌듯함 / 작은 성취",
        "add_determined": "결심함 / 다시 해보려 함"
      }
    },
    "lumen": {
      "name": "루멘",
      "expressions": {
        "lumen_neutral_smirk": "수상한 기본 미소",
        "lumen_teasing": "능글맞게 놀림",
        "lumen_dramatic": "과장되게 비장함",
        "lumen_unhinged_excited": "또라이처럼 신남",
        "lumen_serious": "정색함 / 진심 모드",
        "lumen_gentle": "다정함 / 부드럽게 대해줌"
      }
    }
  },
  "lines": [
    {
      "speaker": "add",
      "expression": "add_neutral_tired",
      "expression_kr": "지쳤지만 기본 상태",
      "text": "...여긴 어디야."
    },
    {
      "speaker": "add",
      "expression": "add_gloomy",
      "expression_kr": "시무룩함 / 풀이 죽음",
      "text": "분명 그냥 좀 걷다가 조용한 데로 온 것뿐인데, 왜 숲이 이렇게 본격적인 거야..."
    },
    {
      "speaker": "lumen",
      "expression": "lumen_dramatic",
      "expression_kr": "과장되게 비장함",
      "text": "도피처 치고는 나쁘지 않은 선택이다."
    },
    {
      "speaker": "add",
      "expression": "add_confused",
      "expression_kr": "당황함 / 어리둥절",
      "text": "누구야?!"
    },
    {
      "speaker": "add",
      "expression": "add_confused",
      "expression_kr": "당황함 / 어리둥절",
      "text": "토끼...?"
    },
    {
      "speaker": "lumen",
      "expression": "lumen_neutral_smirk",
      "expression_kr": "수상한 기본 미소",
      "text": "첫인상이 솔직하군. 마음에 든다."
    },
    {
      "speaker": "add",
      "expression": "add_tsukkomi",
      "expression_kr": "버럭 태클함 / 어이없음",
      "text": "아니 보통 이런 상황이면 '안심하거라, 여행자여' 같은 거부터 하지 않아?"
    },
    {
      "speaker": "lumen",
      "expression": "lumen_dramatic",
      "expression_kr": "과장되게 비장함",
      "text": "안심하거라, 여행자여."
    },
    {
      "speaker": "add",
      "expression": "add_tsukkomi",
      "expression_kr": "버럭 태클함 / 어이없음",
      "text": "늦었어!"
    },
    {
      "speaker": "lumen",
      "expression": "lumen_dramatic",
      "expression_kr": "과장되게 비장함",
      "text": "나는 루멘. 이 숲의 기록관이자 관측자이자 조언자이며, 임시 회계 담당이다."
    },
    {
      "speaker": "add",
      "expression": "add_confused",
      "expression_kr": "당황함 / 어리둥절",
      "text": "임시 회계 담당은 왜 강조하는데."
    },
    {
      "speaker": "lumen",
      "expression": "lumen_teasing",
      "expression_kr": "능글맞게 놀림",
      "text": "전임이 도망쳤다."
    },
    {
      "speaker": "add",
      "expression": "add_tsukkomi",
      "expression_kr": "버럭 태클함 / 어이없음",
      "text": "...불안한데."
    },
    {
      "speaker": "lumen",
      "expression": "lumen_teasing",
      "expression_kr": "능글맞게 놀림",
      "text": "자네, 아주 훌륭한 표정을 하고 있군."
    },
    {
      "speaker": "add",
      "expression": "add_confused",
      "expression_kr": "당황함 / 어리둥절",
      "text": "칭찬 아니지 그거."
    },
    {
      "speaker": "lumen",
      "expression": "lumen_teasing",
      "expression_kr": "능글맞게 놀림",
      "text": "물론 아니지. 저건 '분명 뭔가 하려고 했는데 뭘 하려 했는지 잊어버린 자의 눈'이다."
    },
    {
      "speaker": "add",
      "expression": "add_gloomy",
      "expression_kr": "시무룩함 / 풀이 죽음",
      "text": "......"
    },
    {
      "speaker": "lumen",
      "expression": "lumen_teasing",
      "expression_kr": "능글맞게 놀림",
      "text": "그리고 '잠깐 쉬자' 했더니 시간이 사라진 자의 어깨."
    },
    {
      "speaker": "add",
      "expression": "add_tsukkomi",
      "expression_kr": "버럭 태클함 / 어이없음",
      "text": "그만해. 왜 다 맞아."
    },
    {
      "speaker": "lumen",
      "expression": "lumen_neutral_smirk",
      "expression_kr": "수상한 기본 미소",
      "text": "후후. 나는 토끼니까."
    },
    {
      "speaker": "add",
      "expression": "add_tsukkomi",
      "expression_kr": "버럭 태클함 / 어이없음",
      "text": "그게 이유가 돼?"
    },
    {
      "speaker": "lumen",
      "expression": "lumen_unhinged_excited",
      "expression_kr": "또라이처럼 신남",
      "text": "잘은 모르겠다!"
    },
    {
      "speaker": "lumen",
      "expression": "lumen_serious",
      "expression_kr": "정색함 / 진심 모드",
      "text": "좋아, 잡담은 여기까지. 이 숲은 지금 위기다."
    },
    {
      "speaker": "add",
      "expression": "add_confused",
      "expression_kr": "당황함 / 어리둥절",
      "text": "설마 마왕?"
    },
    {
      "speaker": "lumen",
      "expression": "lumen_serious",
      "expression_kr": "정색함 / 진심 모드",
      "text": "아니."
    },
    {
      "speaker": "add",
      "expression": "add_confused",
      "expression_kr": "당황함 / 어리둥절",
      "text": "저주?"
    },
    {
      "speaker": "lumen",
      "expression": "lumen_serious",
      "expression_kr": "정색함 / 진심 모드",
      "text": "아니."
    },
    {
      "speaker": "add",
      "expression": "add_confused",
      "expression_kr": "당황함 / 어리둥절",
      "text": "그럼 뭐야."
    },
    {
      "speaker": "lumen",
      "expression": "lumen_dramatic",
      "expression_kr": "과장되게 비장함",
      "text": "행정이 밀렸다."
    },
    {
      "speaker": "add",
      "expression": "add_tsukkomi",
      "expression_kr": "버럭 태클함 / 어이없음",
      "text": "...진짜 최악의 판타지네."
    },
    {
      "speaker": "lumen",
      "expression": "lumen_dramatic",
      "expression_kr": "과장되게 비장함",
      "text": "할 일 목록은 정리되지 않았고, 집은 반쯤 지어졌고, 장작은 축축하며, 심부름은 아무도 가지 않았다."
    },
    {
      "speaker": "add",
      "expression": "add_neutral_tired",
      "expression_kr": "지쳤지만 기본 상태",
      "text": "듣기만 해도 피곤해."
    },
    {
      "speaker": "lumen",
      "expression": "lumen_serious",
      "expression_kr": "정색함 / 진심 모드",
      "text": "그래서 자네가 필요하다."
    },
    {
      "speaker": "add",
      "expression": "add_confused",
      "expression_kr": "당황함 / 어리둥절",
      "text": "나?"
    },
    {
      "speaker": "lumen",
      "expression": "lumen_dramatic",
      "expression_kr": "과장되게 비장함",
      "text": "그래. 혼란을 아는 자만이 혼란을 다스릴 수 있다."
    },
    {
      "speaker": "add",
      "expression": "add_tsukkomi",
      "expression_kr": "버럭 태클함 / 어이없음",
      "text": "와, 되게 멋있게 말했는데 그냥 사람 부족하단 뜻이잖아."
    },
    {
      "speaker": "lumen",
      "expression": "lumen_teasing",
      "expression_kr": "능글맞게 놀림",
      "text": "정확하다."
    },
    {
      "speaker": "add",
      "expression": "add_tsukkomi",
      "expression_kr": "버럭 태클함 / 어이없음",
      "text": "조금도 숨기질 않네."
    },
    {
      "speaker": "lumen",
      "expression": "lumen_gentle",
      "expression_kr": "다정함 / 부드럽게 대해줌",
      "text": "하지만 괜찮다. 자네는 아직 자신을 잘 모를 뿐, 생각보다 쓸모 있는 곰일지도 모른다."
    },
    {
      "speaker": "add",
      "expression": "add_gloomy",
      "expression_kr": "시무룩함 / 풀이 죽음",
      "text": "'일지도'가 너무 거슬리는데."
    },
    {
      "speaker": "lumen",
      "expression": "lumen_unhinged_excited",
      "expression_kr": "또라이처럼 신남",
      "text": "그러니 증명해 봐라! 체크하고, 짓고, 패고, 뛰어라!"
    },
    {
      "speaker": "add",
      "expression": "add_confused",
      "expression_kr": "당황함 / 어리둥절",
      "text": "뭐야 이 튜토리얼 대사 같은 건."
    },
    {
      "speaker": "lumen",
      "expression": "lumen_neutral_smirk",
      "expression_kr": "수상한 기본 미소",
      "text": "그리고 100점을 모으면..."
    },
    {
      "speaker": "add",
      "expression": "add_confused",
      "expression_kr": "당황함 / 어리둥절",
      "text": "모으면?"
    },
    {
      "speaker": "lumen",
      "expression": "lumen_teasing",
      "expression_kr": "능글맞게 놀림",
      "text": "이야기가 진행된다."
    },
    {
      "speaker": "add",
      "expression": "add_tsukkomi",
      "expression_kr": "버럭 태클함 / 어이없음",
      "text": "메타발언 하지 마!"
    },
    {
      "speaker": "lumen",
      "expression": "lumen_dramatic",
      "expression_kr": "과장되게 비장함",
      "text": "후후, 자네는 이제 선택해야 한다."
    },
    {
      "speaker": "add",
      "expression": "add_determined",
      "expression_kr": "결심함 / 다시 해보려 함",
      "text": "...좋아. 해보자."
    },
    {
      "speaker": "lumen",
      "expression": "lumen_gentle",
      "expression_kr": "다정함 / 부드럽게 대해줌",
      "text": "좋다. 그럼 지금부터 자네는 이 숲의 임시 행정 곰이다."
    },
    {
      "speaker": "add",
      "expression": "add_tsukkomi",
      "expression_kr": "버럭 태클함 / 어이없음",
      "text": "직책명이 왜 이렇게 불안한데!"
    }
  ]
}